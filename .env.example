# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/file_manager

# Auth Tokens
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRY=7d

# Brevo (Email)
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_EMAIL=noreply@yourdomain.com
BREVO_FROM_NAME=File Manager

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# S3
S3_BUCKET_NAME=your_s3_bucket_name

# CloudFront
CLOUDFRONT_DOMAIN=your_cloudfront_domain
CLOUDFRONT_KEY_PAIR_ID=your_cloudfront_key_pair_id
CLOUDFRONT_PRIVATE_KEY=your_cloudfront_private_key_pem

# SES
SES_FROM_EMAIL=noreply@yourdomain.com

# SQS
SQS_WEBHOOK_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/account/queue-name

# Presigned URL Expiry (seconds)
UPLOAD_URL_EXPIRY=900
DOWNLOAD_URL_EXPIRY=3600

# Multipart Upload Threshold (bytes)
MULTIPART_THRESHOLD=5242880

# Storage
DEFAULT_STORAGE_LIMIT_BYTES=5368709120

# OTP
OTP_EXPIRY_MINUTES=10
